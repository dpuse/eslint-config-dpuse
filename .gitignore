# '.gitignore' configuration for DPUse projects published to npm.
.dev.vars
.env*
.eslintcache
.npmrc
.wrangler
coverage
dist-scripts
node_modules
*.tsbuildinfo
**/.DS_Store

# Logs
logs
*.log
npm-debug.log*

# Rust
rust/*/pkg
rust/*/target
rust/target

# Testing
__screenshots__/
test-results/
playwright-report/
